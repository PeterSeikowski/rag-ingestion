# Copy to .env and fill in real values. Never commit .env.

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO

# --- Redis (Celery broker/result backend + job status store) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
JOB_STATUS_TTL_SECONDS=86400

# --- Elasticsearch (external, not started by this repo) ---
ELASTICSEARCH_URL=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_VERIFY_CERTS=true
ES_DOCUMENTS_INDEX=rag_documents_v1
ES_CHUNKS_INDEX=rag_chunks_v1
ES_EMBEDDINGS_INDEX=rag_embeddings_v1

# --- LiteLLM embeddings ---
LITELLM_MODEL=text-embedding-3-small
LITELLM_API_KEY=changeme
LITELLM_API_BASE=
LITELLM_API_VERSION=
LITELLM_PROVIDER=
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSIONS=

# --- Chunking defaults ---
DEFAULT_CHUNK_SIZE_TOKENS=512
DEFAULT_CHUNK_OVERLAP_TOKENS=64

# --- Parsing ---
DOCLING_ENABLE_OCR=false

# --- Uploads ---
TEMP_UPLOAD_DIR=/tmp/rag_ingestion_uploads
MAX_UPLOAD_SIZE_BYTES=52428800
